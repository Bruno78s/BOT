# =============================================================================
# BZNX BOT - ENVIRONMENT TEMPLATE
# =============================================================================
# Copy this file to .env and fill the values.

NODE_ENV=production

# =============================================================================
# DISCORD - BOT
# =============================================================================

DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
CLIENT_ID=YOUR_DISCORD_APPLICATION_ID
GUILD_ID=YOUR_DISCORD_GUILD_ID

# Single presence fallback. The bot applies it as Discord custom status automatically.
BOT_PRESENCE_MESSAGE=LOJA ONLINE
BOT_PRESENCE_TYPE=CUSTOM

# Rotating presence list. Use only messages; legacy TYPE:message values are also accepted.
BOT_PRESENCE_ACTIVITIES=ENTREGAS ON;LOJA ONLINE;MELHORES PRODUTOS AQUI;BOTS E SITES SOB MEDIDA;ATENDIMENTO BZNX STORE
BOT_PRESENCE_ROTATE_INTERVAL_MS=60000

# Verification and invite safety.
VERIFICATION_MIN_ACCOUNT_AGE_DAYS=7
INVITE_MIN_ACCOUNT_AGE_DAYS=7
INVITE_VALID_AFTER_MINUTES=30

# Ticket automation and anti-spam.
MAX_OPEN_TICKETS_PER_USER=2
TICKET_AUTO_CLOSE_WARN_HOURS=12
TICKET_AUTO_CLOSE_HOURS=24
TICKET_AUTO_CLOSE_CHECK_MS=600000

# Optional log/boost/status channels. Fill only if you use these features.
AUDIT_LOG_CHANNEL_ID=
BOOST_ANNOUNCE_CHANNEL_ID=
BOOSTER_ROLE_ID=
STATUS_PANEL_CHANNEL_ID=

# Private administrative receipt channel. The PDF is generated after real payment approval.
RECEIPT_CHANNEL_ID=1469735330511851732

# Send the approved PDF receipt to the customer DM too. Keep false if you want staff-only receipts.
SEND_RECEIPT_DM=false

# =============================================================================
# BZNX STORE - DISCORD CUSTOMER ROLE SYNC
# =============================================================================

BZNX_SITE_URL=https://bznx-store.duckdns.org
BZNX_INTEGRATION_API_KEY=
BZNX_CUSTOMER_ROLE_SYNC_INTERVAL_MS=120000

DISCORD_GUILD_ID=YOUR_DISCORD_GUILD_ID
DISCORD_CUSTOMER_ROLE_ID=YOUR_CUSTOMER_ROLE_ID

# Compatibility with the older local payment flow that reads CLIENT_ROLE_ID.
CLIENT_ROLE_ID=YOUR_CUSTOMER_ROLE_ID

# =============================================================================
# BZNX STORE - URLS
# =============================================================================

CLIENT_URL=https://bznx-store.duckdns.org

# =============================================================================
# WEBHOOK SERVER
# =============================================================================

WEBHOOK_PORT=3000

# Safety net: the bot checks Mercado Pago pending payments even if the webhook does not arrive.
MERCADO_PAGO_PENDING_CHECK_INTERVAL_MS=30000

# =============================================================================
# MERCADO PAGO - PIX
# =============================================================================

MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_WEBHOOK_URL=https://bznx-store.duckdns.org/api/pix/webhook

# Optional payer email override. Leave empty to auto-generate per user.
MERCADO_PAGO_PAYER_EMAIL=

# =============================================================================
# CARTAO - CHECKOUT
# =============================================================================

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://bznx-store.duckdns.org/pagamento/sucesso?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://bznx-store.duckdns.org/pagamento/cancelado

# =============================================================================
# SUPABASE
# =============================================================================

SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# =============================================================================
# BACKUP
# =============================================================================

JWT_SECRET=
BACKUP_ENCRYPTION_KEY=

# =============================================================================
# AUTO RESTOCK
# =============================================================================

AUTO_RESTOCK_ENABLED=true
AUTO_RESTOCK_THRESHOLD=5
AUTO_RESTOCK_QUANTITY=20

# =============================================================================
# DEBUG
# =============================================================================

DEBUG_RUN_ID=
