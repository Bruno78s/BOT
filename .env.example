# ==========================================
# CONFIGURAÇÃO DO BOT DISCORD
# ==========================================

# Token do bot Discord (obrigatório)
# Obtenha em: https://discord.com/developers/applications
DISCORD_TOKEN=SEU_TOKEN_AQUI

# ID do bot/cliente (obrigatório)
# Encontre no Discord Developer Portal
CLIENT_ID=SEU_CLIENT_ID_AQUI

# ID do servidor/guild (obrigatório)
GUILD_ID=SEU_GUILD_ID_AQUI

# ==========================================
# MERCADO PAGO (Pagamento via PIX)
# ==========================================

# Access Token de produção (começa com APP_USR-)
# Obtenha em: https://www.mercadopago.com.br/developers/panel/credentials
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-SEU_TOKEN_AQUI

# Secret do webhook para verificação de segurança
# Configure em: https://www.mercadopago.com.br/developers/panel/webhooks
MERCADO_PAGO_WEBHOOK_SECRET=SEU_SECRET_AQUI

# URL do webhook (para receber notificações de pagamento)
# Exemplo: https://seu-dominio.com/mercadopago/webhook
# Ou para teste local: https://ngrok-url.ngrok-free.app/mercadopago/webhook
MERCADO_PAGO_WEBHOOK_URL=SEU_WEBHOOK_URL_AQUI

# Email do pagador (opcional - para testes)
MERCADO_PAGO_PAYER_EMAIL=cliente@seusite.com

# ==========================================
# SERVIDOR WEBHOOK
# ==========================================

# Porta do servidor webhook (padrão: 3000)
WEBHOOK_PORT=3000

# ==========================================
# SUPABASE (Banco de Dados - Opcional)
# ==========================================

# URL do projeto Supabase
SUPABASE_URL=https://seu-projeto.supabase.co

# Service Role Key (chave secreta - não compartilhe!)
SUPABASE_SERVICE_ROLE=sua_chave_aqui

# ==========================================
# CONFIGURAÇÕES OPCIONAIS
# ==========================================

# Ambiente (development/production)
NODE_ENV=production

# Porta da aplicação (se diferente do webhook)
PORT=3000
