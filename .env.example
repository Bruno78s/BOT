# =============================================================================
# BZN STORE BOT - CONFIGURAÇÃO DE AMBIENTE
# Copie este arquivo para .env e preencha com os valores reais
# =============================================================================

# =============================================================================
# DISCORD - BOT
# =============================================================================

# Token do bot Discord (obrigatório)
# Obtenha em: https://discord.com/developers/applications
DISCORD_TOKEN=SEU_TOKEN_AQUI

# ID do bot/cliente (obrigatório)
# Encontre no Discord Developer Portal
CLIENT_ID=SEU_CLIENT_ID_AQUI

# ID do servidor/guild (obrigatório)
GUILD_ID=SEU_GUILD_ID_AQUI

# =============================================================================
# MERCADO PAGO - PIX
# =============================================================================

# Access Token de produção (começa com APP_USR-)
# Obtenha em: https://www.mercadopago.com.br/developers/panel/credentials
MERCADOPAGO_ACCESS_TOKEN=APP_USR-SEU_TOKEN_AQUI

# Secret do webhook para verificação de segurança
# Configure em: https://www.mercadopago.com.br/developers/panel/webhooks
MERCADOPAGO_WEBHOOK_SECRET=SEU_SECRET_AQUI

# URL do webhook (para receber notificações de pagamento)
# Configure para usar a mesma URL do site: /api/pix/webhook
MERCADO_PAGO_WEBHOOK_URL=https://bznx-store.duckdns.org/api/pix/webhook



# =============================================================================
# SERVIDOR WEBHOOK
# =============================================================================

# Porta do servidor webhook (padrão: 3000)
# Se o site usa outra porta (3002), mantenha o bot na 3000 ou mude se necessário
WEBHOOK_PORT=3000

# =============================================================================
# SUPABASE - BANCO DE DADOS (Opcional mas recomendado)
# =============================================================================

# URL do projeto Supabase (mesmo do site)
SUPABASE_URL=https://omodwcacuxzitbegcwka.supabase.co

# Service Role Key (chave secreta - obtida em Settings > API)
# ATENÇÃO: Esta chave tem privilégios de admin. Nunca exponha no frontend!
SUPABASE_SERVICE_ROLE=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9tb2R3Y2FjdXh6aXRiZWdjd2thIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3ODYxMTI5MSwiZXhwIjoyMDk0MTg3MjkxfQ.XRxC6vkx-jB2zdIXvcz6QIHmX-yea9guvKSr5o-jVw0

# =============================================================================
# CONFIGURAÇÕES OPCIONAIS
# =============================================================================

# Ambiente (development/production)
NODE_ENV=production
